	QJS_NewBigInt64, QJS_NewBigUint64


quickjs.library/QJS_SetIsHTMLDDA                 quickjs.library/QJS_SetIsHTMLDDA

    NAME
	QJS_SetIsHTMLDDA -- Mark an object as the HTML
	    "all" pseudo-undefined.

    SYNOPSIS
	QJS_SetIsHTMLDDA(ctx, obj_ptr)
			 A0   A1

	VOID QJS_SetIsHTMLDDA(JSContext *ctx,
			      const JSValue *obj_ptr);

    FUNCTION
	Marks an object as a "default-default attribute" object
	(IsHTMLDDA), giving it the strange ECMAScript-defined
	behaviour where it compares == to undefined and to null.
	Originally specified to support the legacy
	`document.all` browser quirk.

	Almost no code outside the test suite needs this.

    INPUTS
	ctx	- Host context.
	obj_ptr - Pointer to the object to mark.

    RESULT
	None.


quickjs.library/QJS_GetLibcOpaque               quickjs.library/QJS_GetLibcOpaque

    NAME
	QJS_GetLibcOpaque -- Read the std/os module's opaque
	    pointer.

    SYNOPSIS
	ptr = QJS_GetLibcOpaque(rt)
	D0                      A0

	APTR QJS_GetLibcOpaque(JSRuntime *rt);

    FUNCTION
	Returns whatever was stored via QJS_SetLibcOpaque().
	Used internally by the std/os modules to keep per-runtime
	state (file-handle table, signal handlers, etc.).

    INPUTS
	rt - The runtime.

    RESULT
	ptr - Stored pointer, or NULL.

    SEE ALSO
	QJS_SetLibcOpaque


quickjs.library/QJS_SetLibcOpaque               quickjs.library/QJS_SetLibcOpaque

    NAME
	QJS_SetLibcOpaque -- Store the std/os module's opaque
	    pointer.

    SYNOPSIS
	QJS_SetLibcOpaque(rt, opaque)
			  A0  A1

	VOID QJS_SetLibcOpaque(JSRuntime *rt, APTR opaque);

    FUNCTION
	Stashes a pointer for use by the std/os modules.  Set
	automatically by QJS_StdInitHandlers(); rarely useful
	for application code.

    INPUTS
	rt     - The runtime.
	opaque - Pointer to store.

    RESULT
	None.

    SEE ALSO
	QJS_GetLibcOpaque, QJS_StdInitHandlers


quickjs.library/QJS_InitModuleStd               quickjs.library/QJS_InitModuleStd

    NAME
	QJS_InitModuleStd -- Register the "qjs:std" module.

    SYNOPSIS
	m = QJS_InitModuleStd(ctx, module_name)
	D0                    A0   A1

	JSModuleDef *QJS_InitModuleStd(JSContext *ctx,
				       CONST_STRPTR module_name);

    FUNCTION
	Registers the standard "qjs:std" module which exposes
	std.printf, std.open, std.urlGet, std.exit, etc.

	Call this if your application wants the std module
	available for `import * as std from 'qjs:std'`.

    INPUTS
	ctx	    - Host context.
	module_name - Name to register the module as.  Pass
		      "qjs:std" for compatibility with the qjs CLI.

    RESULT
	m - Module def, or NULL on failure.

    SEE ALSO
	QJS_InitModuleOS, QJS_InitModuleBJSON,
	QJS_StdAddHelpers


quickjs.library/QJS_InitModuleOS                 quickjs.library/QJS_InitModuleOS

    NAME
	QJS_InitModuleOS -- Register the "qjs:os" module.

    SYNOPSIS
	m = QJS_InitModuleOS(ctx, module_name)
	D0                   A0   A1

	JSModuleDef *QJS_InitModuleOS(JSContext *ctx,
				      CONST_STRPTR module_name);

    FUNCTION
	Registers the "qjs:os" module: file system access,
	process control, timers, signal handling, environment
	variables.

    INPUTS
	ctx	    - Host context.
	module_name - Module name (typically "qjs:os").

    RESULT
	m - Module def, or NULL on failure.

    SEE ALSO
	QJS_InitModuleStd, QJS_InitModuleBJSON


quickjs.library/QJS_InitModuleBJSON           quickjs.library/QJS_InitModuleBJSON

    NAME
	QJS_InitModuleBJSON -- Register the "qjs:bjson" binary
	    JSON module.

    SYNOPSIS
	m = QJS_InitModuleBJSON(ctx, module_name)
	D0                      A0   A1

	JSModuleDef *QJS_InitModuleBJSON(JSContext *ctx,
					 CONST_STRPTR module_name);

    FUNCTION
	Registers the binary-JSON serialization module
	(bjson.read / bjson.write).  More compact and faster than
	JSON.parse/stringify for round-tripping JS values.

    INPUTS
	ctx	    - Host context.
	module_name - Module name.

    RESULT
	m - Module def, or NULL on failure.

    SEE ALSO
	QJS_InitModuleStd, QJS_InitModuleOS


quickjs.library/QJS_StdInitHandlers             QJS_StdInitHandlers

    NAME
	QJS_StdInitHandlers -- Set up the runtime for std/os.

    SYNOPSIS
	QJS_StdInitHandlers(rt)
			    A0

	VOID QJS_StdInitHandlers(JSRuntime *rt);

    FUNCTION
	Initializes per-runtime state used by the std and os
	modules: opens file descriptors 0/1/2, sets up the
	timer queue, registers the standard interrupt handler
	(Ctrl-C detection).

	Call once after QJS_NewRuntime() if your application
	intends to use std/os.  Pair with
	QJS_StdFreeHandlers() before QJS_FreeRuntime().

    INPUTS
	rt - The runtime.

    RESULT
	None.

    SEE ALSO
	QJS_StdFreeHandlers, QJS_StdAddHelpers, QJS_StdLoop


quickjs.library/QJS_StdFreeHandlers             QJS_StdFreeHandlers

    NAME
	QJS_StdFreeHandlers -- Tear down std/os runtime state.

    SYNOPSIS
	QJS_StdFreeHandlers(rt)
			    A0

	VOID QJS_StdFreeHandlers(JSRuntime *rt);

    FUNCTION
	Releases anything QJS_StdInitHandlers() allocated.
	Must be called before QJS_FreeRuntime() if
	QJS_StdInitHandlers() was used.

    INPUTS
	rt - The runtime.

    RESULT
	None.

    SEE ALSO
	QJS_StdInitHandlers, QJS_FreeRuntime


quickjs.library/QJS_StdAddHelpers               QJS_StdAddHelpers

    NAME
	QJS_StdAddHelpers -- Install global helpers (print,
	    console.log, scriptArgs, fetch).

    SYNOPSIS
	QJS_StdAddHelpers(ctx, argc, argv)
			  A0   D0    A1

	VOID QJS_StdAddHelpers(JSContext *ctx, int argc,
			       STRPTR *argv);

    FUNCTION
	Installs convenience globals on the context:

	    print()       -- write args to stdout
	    console.log() -- alias for print
	    scriptArgs    -- array of command-line arguments
	    fetch()       -- async HTTP/HTTPS (Amiga port)

	Required for typical script execution; safely no-op
	if called twice.

    INPUTS
	ctx  - Host context.
	argc - Argument count for scriptArgs.
	argv - Argument strings, or NULL if argc <= 0.

    RESULT
	None.

    SEE ALSO
	QJS_StdInitHandlers, QJS_StdLoop


quickjs.library/QJS_StdLoop                         quickjs.library/QJS_StdLoop

    NAME
	QJS_StdLoop -- Run the event loop until idle.

    SYNOPSIS
	rc = QJS_StdLoop(ctx)
	D0               A0

	LONG QJS_StdLoop(JSContext *ctx);

    FUNCTION
	Drives the runtime's event loop: drains the microtask
	queue, fires expired setTimeout/setInterval timers,
	dispatches I/O on registered file descriptors, and
	repeats until everything is idle.

	Returns when:
	    * no more pending jobs / timers / handlers, OR
	    * an unhandled exception bubbled up.

    INPUTS
	ctx - Host context.

    RESULT
	rc - 0 on clean exit, non-zero if an exception bubbled
	     out (already printed via QJS_StdDumpError if it
	     reached top level).

    EXAMPLE
	/* Standard CLI lifecycle: */
	QJS_EvalBuf(ctx, src, len, "main.js", JS_EVAL_TYPE_MODULE);
	QJS_StdLoop(ctx);

    SEE ALSO
	QJS_IsJobPending, QJS_ExecutePendingJob


quickjs.library/QJS_StdEvalBinary               QJS_StdEvalBinary

    NAME
	QJS_StdEvalBinary -- Evaluate a precompiled bytecode
	    blob.

    SYNOPSIS
	QJS_StdEvalBinary(ctx, buf, buf_len, flags)
			  A0   A1   D0       D1

	VOID QJS_StdEvalBinary(JSContext *ctx, const UBYTE *buf,
			       ULONG buf_len, ULONG flags);

    FUNCTION
	Loads a buffer produced by qjsc -e, links references,
	resolves the global object, and executes.  Used by
	standalone executables that have JS bytecode embedded
	in their data segment.

    INPUTS
	ctx	- Host context.
	buf	- Bytecode blob.
	buf_len - Length in bytes.
	flags	- 0 normally, or JS_LOAD_ONLY to link without
		  executing.

    RESULT
	None.  Errors are printed via QJS_StdDumpError.

    SEE ALSO
	QJS_ReadObject, QJS_StdLoop


quickjs.library/QJS_StdDumpError                 QJS_StdDumpError

    NAME
	QJS_StdDumpError -- Print the pending exception to stderr.

    SYNOPSIS
	QJS_StdDumpError(ctx)
			 A0

	VOID QJS_StdDumpError(JSContext *ctx);

    FUNCTION
	If an exception is pending on the context, fetches it
	and prints its message and stack trace to stderr in a
	human-friendly format.  Clears the exception.

	If no exception is pending, prints nothing.

    INPUTS
	ctx - Host context.

    RESULT
	None.

    SEE ALSO
	QJS_GetException, QJS_HasException


quickjs.library/QJS_LoadFile                         QJS_LoadFile

    NAME
	QJS_LoadFile -- Read a file into engine-allocated memory.

    SYNOPSIS
	buf = QJS_LoadFile(ctx, pbuf_len, filename)
	D0                 A0   A1        A2

	UBYTE *QJS_LoadFile(JSContext *ctx, size_t *pbuf_len,
			    CONST_STRPTR filename);

    FUNCTION
	Reads the entire file `filename` into a freshly-allocated
	buffer (with a trailing NUL byte not counted in *pbuf_len).
	Uses dos.library Open()/Read() and accepts AmigaOS-style
	paths (RAM:, S:, volume-rooted, etc.).

	Free the buffer with QJS_Free() when done.

    INPUTS
	ctx	 - Host context.
	pbuf_len - Output for byte length, or NULL.
	filename - Path to the file.

    RESULT
	buf - Newly-allocated buffer, or NULL on error.

    EXAMPLE
	size_t len;
	UBYTE *src = QJS_LoadFile(ctx, &len, "RAM:script.js");
	if (src) {
	    QJS_EvalBuf(ctx, (CONST_STRPTR)src, len, "RAM:script.js",
			JS_EVAL_TYPE_GLOBAL);
	    QJS_Free(ctx, src);
	}

    SEE ALSO
	QJS_Free, QJS_EvalBuf





quickjs.library/QJS_GetMathBase               quickjs.library/QJS_GetMathBase

    NAME
	QJS_GetMathBase -- Get a library-owned IEEE math base pointer.

    SYNOPSIS
	base = QJS_GetMathBase(which)
	D0		       D0

	struct Library *QJS_GetMathBase(ULONG which);

    FUNCTION
	Returns a pointer to one of the math libraries quickjs.library
	has already opened for its own use.  The library opens these
	once during initialization; callers should just read them here
	rather than duplicating the OpenLibrary call.

	This exists so that a softfloat-compiled client (e.g. the qjs
	CLI built with no -fpu) can wire its VBCC-generated
	MathIeeeDoubBasBase / MathIeeeDoubTransBase globals to the
	same bases quickjs.library already holds.  Refcounting stays
	balanced: the library owns OpenLibrary, you never call
	CloseLibrary on what this returns.

    INPUTS
	which - Selector:
		0 = mathieeedoubbas.library
		1 = mathieeedoubtrans.library
		(other values return NULL)

    RESULT
	base - Pointer to the requested library, or NULL if the
	    selector is unknown or the library never opened it.

    EXAMPLE
	/* In a softfloat CLI's startup code, after OpenLibrary of
	 * quickjs.library: */
	extern struct Library *MathIeeeDoubBasBase;
	extern struct Library *MathIeeeDoubTransBase;
	MathIeeeDoubBasBase   = QJS_GetMathBase(0);
	MathIeeeDoubTransBase = QJS_GetMathBase(1);

    NOTES
	mathieeesingbas.library is intentionally NOT exposed here;
	printf %f and JSValue int64<->double conversions use only
	DoubBas and DoubTrans.  If you need SingBas you can open it
	yourself without breaking refcount hygiene.

    SEE ALSO
	QJS_GetNetCapabilities, QJS_GetVersion


quickjs.library/QJS_GetNetCapabilities quickjs.library/QJS_GetNetCapabilities

    NAME
	QJS_GetNetCapabilities -- Query which network stacks the
	    library successfully probed at load time.

    SYNOPSIS
	caps = QJS_GetNetCapabilities()
	D0

	ULONG QJS_GetNetCapabilities(VOID);

    FUNCTION
	Returns a bitmask of networking capabilities that quickjs.library
	confirmed at CustomLibInit time by opening and closing the
	relevant system libraries once.

	The library loads unconditionally even if both probes fail; it
	just reports zero caps.  fetch() checks this mask before
	attempting a request and throws a clear TypeError naming the
	missing library, rather than letting the failure manifest
	opaquely inside a worker task.

    INPUTS
	None.

    RESULT
	caps - Bitmask:
		QJS_NET_TCP (0x01) = bsdsocket.library v4+ available
		QJS_NET_TLS (0x02) = amisslmaster.library available

    EXAMPLE
	ULONG caps = QJS_GetNetCapabilities();
	if (!(caps & QJS_NET_TCP)) {
	    Printf("http:// not supported; install bsdsocket.library\n");
	}
	if (!(caps & QJS_NET_TLS)) {
	    Printf("https:// not supported; install AmiSSL\n");
	}

    NOTES
	The qjs:net JS module exposes this same information via
	Networking.hasTCP(), Networking.hasTLS(), Networking.status()
	and Networking.reprobe() (the latter re-runs the probe to
	pick up newly-installed libraries at runtime).

    SEE ALSO
	QJS_InitModuleNet, --background--


quickjs.library/QJS_InitModuleNet           quickjs.library/QJS_InitModuleNet

    NAME
	QJS_InitModuleNet -- Register the "qjs:net" JS module.

    SYNOPSIS
	m = QJS_InitModuleNet(ctx, module_name)
	D0		      A0   A1

	JSModuleDef *QJS_InitModuleNet(JSContext *ctx,
				       CONST_STRPTR module_name);

    FUNCTION
	Registers a C module in ctx that exports the Networking
	capability API.  After this call, JavaScript code can
	`import * as Networking from "qjs:net"` and use:

	    Networking.hasTCP()  -- boolean
	    Networking.hasTLS()  -- boolean
	    Networking.status()  -- { tcp, tls }
	    Networking.reprobe() -- { tcp, tls } (also refreshes)

    INPUTS
	ctx	    - Context that should expose the module.
	module_name - Module identifier, typically "qjs:net".

    RESULT
	m - The new module, or NULL on failure.

    SEE ALSO
	QJS_InitModuleStd, QJS_InitModuleOS, QJS_GetNetCapabilities


quickjs.library/QJS_InstallChildProcessGlobal  quickjs.library/QJS_InstallChildProcessGlobal

    NAME
	QJS_InstallChildProcessGlobal -- Install native spawnSync on
	    globalThis.__qjs_spawnSync for the given context.

    SYNOPSIS
	QJS_InstallChildProcessGlobal(ctx)
				      A0

	void QJS_InstallChildProcessGlobal(JSContext *ctx);

    FUNCTION
	Attaches a native C function to
	globalThis.__qjs_spawnSync(cmdline).  The function runs
	cmdline synchronously via dos.library SystemTagList, with
	SYS_Output and SYS_Error redirected to T:qjs-cp-<task>-out
	and T:qjs-cp-<task>-err temp files.  After the child exits
	the files are slurped, their contents returned as an object:

	    { stdout: string,
	      stderr: string,
	      exitCode: number,
	      signal: null }

	extended.js (Amiga CLI startup bundle) wraps this native
	function in a Node-compatible globalThis.child_process
	object exposing spawnSync(), spawn() (Promise),
	execSync() and exec() (Promise).

	SYS_Error is V50+ only.  On Kickstart V47 the child's stderr
	falls through to the console instead of our temp file -- the
	result.stderr string will be empty but stdout and exitCode
	still work.

    INPUTS
	ctx - Context that should receive globalThis.__qjs_spawnSync.

    RESULT
	None.  Overwrites any previous binding if called again.

    SEE ALSO
	QJS_InitModuleNet, QJS_WorkerSpawn, --overview--


quickjs.library/QJS_WorkerSpawn               quickjs.library/QJS_WorkerSpawn

    NAME
	QJS_WorkerSpawn -- Launch a native Task that runs a C job
	    function with its own per-task library bases.

    SYNOPSIS
	worker = QJS_WorkerSpawn(job_fn, user_data, flags)
	D0			 A0	 A1	    D0

	typedef LONG (*QJSWorkerJobFn)(struct QJSWorker *w, APTR user);
	struct QJSWorker *QJS_WorkerSpawn(QJSWorkerJobFn job_fn,
					  APTR user_data,
					  ULONG flags);

    FUNCTION
	Creates a new AmigaOS Task that runs job_fn(worker, user_data)
	and exits when job_fn returns.  The framework opens
	bsdsocket.library, amisslmaster.library, and dos.library with
	their own per-task bases in the child task -- this is required
	because several AmigaOS system libraries keep per-task state
	and hang if two tasks share a single library base.

	The caller's Task may continue immediately; use QJS_WorkerPoll
	to check progress without blocking or QJS_WorkerJoin to wait.

	Documented in docs/WORKER_API.md with the full concurrency
	model and signal/MsgPort semantics.

    INPUTS
	job_fn	  - Entry function to execute in the new Task.
	user_data - Arbitrary pointer passed through to job_fn.
	flags	  - Reserved for future use; pass 0.

    RESULT
	worker - Opaque handle for Poll/Join/GetBase/Destroy, or NULL
	    on failure (memory, Task creation, etc.).

    EXAMPLE
	static LONG my_job(struct QJSWorker *w, APTR ud) {
	    /* Worker's bsdsocket base: */
	    struct Library *sb = QJS_WorkerGetBase(w, 0);
	    /* ... do work ... */
	    return 0;
	}
	struct QJSWorker *w = QJS_WorkerSpawn(my_job, NULL, 0);
	if (w) {
	    LONG rc = QJS_WorkerJoin(w);
	    QJS_WorkerDestroy(w);
	}

    NOTES
	DO NOT touch the worker handle from inside job_fn with the
	expectation that it reflects job state -- job_fn runs AS the
	worker, so fields like state are updated after job_fn returns.
	Use QJS_WorkerGetBase from within job_fn to access its
	per-task library bases.

    SEE ALSO
	QJS_WorkerPoll, QJS_WorkerJoin, QJS_WorkerDestroy,
	QJS_WorkerGetBase


quickjs.library/QJS_WorkerPoll                 quickjs.library/QJS_WorkerPoll

    NAME
	QJS_WorkerPoll -- Non-blocking state check for a worker.

    SYNOPSIS
	state = QJS_WorkerPoll(worker)
	D0		       A0

	LONG QJS_WorkerPoll(struct QJSWorker *worker);

    FUNCTION
	Returns the worker's current state without blocking.  Safe to
	call from the spawning Task at any frequency.  Typical use is
	a short loop that does other work while awaiting completion.

    INPUTS
	worker - Handle from QJS_WorkerSpawn.  NULL is treated as
	    "failed".

    RESULT
	state - One of:
		QJS_WORKER_PENDING (0) -- not yet started
		QJS_WORKER_RUNNING (1) -- job_fn executing
		QJS_WORKER_DONE    (2) -- job_fn returned normally
		QJS_WORKER_FAILED  (3) -- framework error or NULL

    SEE ALSO
	QJS_WorkerSpawn, QJS_WorkerJoin


quickjs.library/QJS_WorkerJoin                 quickjs.library/QJS_WorkerJoin

    NAME
	QJS_WorkerJoin -- Block the caller until a worker finishes.

    SYNOPSIS
	rc = QJS_WorkerJoin(worker)
	D0		    A0

	LONG QJS_WorkerJoin(struct QJSWorker *worker);

    FUNCTION
	Blocks the calling Task on the worker's reply MsgPort until
	job_fn has returned (or framework setup failed), then returns
	the value job_fn returned.  Kernel-level wait -- the calling
	Task consumes no CPU while waiting.

	After a successful Join, the worker handle is in the DONE
	state; call QJS_WorkerDestroy to release its resources.

    INPUTS
	worker - Handle from QJS_WorkerSpawn.  NULL returns -1.

    RESULT
	rc - The LONG returned by job_fn, or -1 on worker==NULL or
	    framework error.

    NOTES
	Calling Join twice on the same worker is safe; the second
	call returns immediately with the cached result.

    SEE ALSO
	QJS_WorkerSpawn, QJS_WorkerPoll, QJS_WorkerDestroy


quickjs.library/QJS_WorkerDestroy           quickjs.library/QJS_WorkerDestroy

    NAME
	QJS_WorkerDestroy -- Free a worker handle and its resources.

    SYNOPSIS
	QJS_WorkerDestroy(worker)
			  A0

	VOID QJS_WorkerDestroy(struct QJSWorker *worker);

    FUNCTION
	Releases the worker struct, its reply MsgPort, and any
	framework-allocated buffers.  If the worker is still RUNNING
	when this is called, a QJS_WorkerJoin is performed first to
	prevent use-after-free.

	Safe on NULL -- it's a no-op.  Safe to call after Join.

    INPUTS
	worker - Handle from QJS_WorkerSpawn.

    RESULT
	None.

    SEE ALSO
	QJS_WorkerSpawn, QJS_WorkerJoin


quickjs.library/QJS_WorkerGetBase           quickjs.library/QJS_WorkerGetBase

    NAME
	QJS_WorkerGetBase -- Retrieve one of the worker's per-task
	    library bases.

    SYNOPSIS
	base = QJS_WorkerGetBase(worker, which)
	D0			 A0	 D0

	struct Library *QJS_WorkerGetBase(struct QJSWorker *worker,
					  ULONG which);

    FUNCTION
	Returns one of the per-task library bases the framework opened
	for the worker.  Must only be called FROM WITHIN job_fn, for
	the worker that's running -- bsdsocket, AmiSSL, and dos bases
	stashed in the worker struct are task-local and MUST NOT be
	used from any other Task.

    INPUTS
	worker - The currently-running worker handle (passed to job_fn).
	which  - Selector:
		 QJS_WORKER_BASE_SOCKET  (0) = bsdsocket.library
		 QJS_WORKER_BASE_SSL     (1) = amisslmaster.library
		 QJS_WORKER_BASE_DOS     (2) = dos.library

    RESULT
	base - Per-task library base, or NULL if the worker failed
	    to open that library at spawn time.

    NOTES
	Returning a non-NULL bsdsocket base out of job_fn and then
	using it from the parent task is a guaranteed hang on
	AmigaOS.  Don't do it.

    SEE ALSO
	QJS_WorkerSpawn

