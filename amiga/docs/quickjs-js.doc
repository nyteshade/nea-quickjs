	os.getcwd() -- Get the current working directory.


quickjs-js/os.getenv                                          quickjs-js/os.getenv

    NAME
	os.getenv(name) -- Read an env variable.

    SEE ALSO
	std.getenv, os.getvar


quickjs-js/os.getvar                                          quickjs-js/os.getvar

    NAME
	os.getvar(name, flags?) -- Read an AmigaOS dos variable.

    NOTES
	Uses dos.library GetVar().  More flexible than getenv()
	for AmigaOS-specific variable scopes.

    SEE ALSO
	os.setvar


quickjs-js/os.setvar                                          quickjs-js/os.setvar

    NAME
	os.setvar(name, value, flags?) -- Set a dos variable.

    NOTES
	Uses dos.library SetVar().


quickjs-js/bjson.read                                        quickjs-js/bjson.read

    NAME
	bjson.read(buf, offset?, length?) -- Decode a binary JSON
	    buffer.

    USAGE
	import * as bjson from 'qjs:bjson';
	const value = bjson.read(buf);

    NOTES
	Reads the QuickJS native binary serialization format.
	Faster and smaller than JSON.parse for round-tripping
	JS values; not interoperable with other languages.

    SEE ALSO
	bjson.write


quickjs-js/bjson.write                                      quickjs-js/bjson.write

    NAME
	bjson.write(value) -- Encode a JS value to binary.

    USAGE
	const buf = bjson.write({ a: [1, 2, 3] });

    RETURN
	ArrayBuffer.

    SEE ALSO
	bjson.read

