.key KEYMAP/A
.bra <
.ket >


SetVNC IfVNC
if WARN
	C:SetKeyBoard <KEYMAP>
else
	if "<KEYMAP>" eq "usa"
		echo "*E]42;usa"
	else
		if "<KEYMAP>" eq "usa1"
			echo "*E]42;usa1"
		else
			if exists KEYMAPS:<KEYMAP>
				echo "*E]42;<KEYMAP>"
			else
				echo "ERROR: Can't load keymap <KEYMAP>"
			endif
		endif
	endif
endif
