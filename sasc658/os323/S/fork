.KEY COMMAND,ARG0,ARG1,ARG2,ARG3,ARG4,ARG5,ARG6,ARG7,ARG8,ARG9 
.BRA {
.KET }

if not exists ENV:newid
	setenv newid 0
endif
if "{COMMAND}" eq ""
	run NewCLI window=CONSOLE:fork$newid >NIL:
	SetVNC background
else
	run {COMMAND} {ARGS} {ARG0} {ARG1} {ARG2} {ARG3} {ARG4} {ARG5} {ARG6} {ARG7} {ARG8} {ARG9} >CONSOLE:fork$newid <CONSOLE:fork$newid
endif
setenv newid `eval $newid + 1`
