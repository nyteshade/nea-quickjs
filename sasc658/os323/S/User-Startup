; User-startup for hard drive systems
;
;+-------------------------------------------------------------------+
;| This is the User-startup script. Here you can write down the      |
;| names of the programs you wish to have automatically run every    |
;| time your machine boots.                                          |
;|                                                                   |
;| Lines starting with the ";" symbol are ignored and used as        |
;| comments.                                                         | 
;+-------------------------------------------------------------------+
;

Assign Code: Sys:Developer
Assign Arcs: Sys:Arcs
Assign Media: Sys:Media
Assign Prefs: Sys:Prefs
Assign Applications: Sys:Programs

;BEGIN AmiSSL
Assign AmiSSL: "DH0:Internet/AmiSSL"
If Exists AmiSSL:Libs
  Assign LIBS: AmiSSL:Libs ADD
EndIf
Path AmiSSL: ADD
;END AmiSSL

;BEGIN MUI
if exists "Sys:System/MUI"
   assign MUI: "Sys:System/MUI"
   if exists MUI:Libs
      assign add LIBS: MUI:Libs
   endif
   if exists MUI:Locale
      assign add LOCALE: MUI:Locale
   endif
   version >nil: exec.library 39
   if not warn
      if exists MUI:Docs
         if exists HELP:dummy ; do not remove
         endif                ; this entry!
         assign add HELP: MUI:Docs
      endif
   endif
endif
;END MUI
;BEGIN VNC
;Mount VNC:
SYS:C/SetVNC Quiet Mount Override as CON:
;END VNC
;BEGIN StringSnip
SYS:C/StringSnip >NIL: install
;END StringSnip
;BEGIN TrueMultiAssigns
SYS:C/TrueMultiAssigns
;END TrueMultiAssigns
