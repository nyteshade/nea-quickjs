/*
**   GetFilePart: Extracts the file name from a full file specification.
** So long as that spec is valid, this should not fail.
*/

GetFilePart:

Parse ARG path

dirend = LastPos('/', path)
if dirend = 0 then
    dirend = Pos(':',path)
if dirend ~= 0 then
    file = SubStr(path,dirend+1)

Return file

