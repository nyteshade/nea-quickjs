OBJS= mkmk.o dofile.o gensmake.o

# Build the stripped version, mkmk, from the debug version, mkmk.db
mkmk: mkmk.db
   slink mkmk.db to mkmk nd

# Build the debug version by linking all the objects
# List the GST file first in the dependancy list so it gets rebuild first
mkmk.db: mkmk.gst $(OBJS)
   sc link to mkmk.db with <<
$(OBJS)
<

# Rule for building the GST file
mkmk.gst: mkmk.h mkmk_protos.h DoFile_protos.h GenSmake_protos.h
   sc mkmk.c mgst mkmk.gst noobjname

#Rules for individual .o files

mkmk.o: mkmk.c mkmk.h mkmk_protos.h DoFile_protos.h GenSmake_protos.h

dofile.o: dofile.c mkmk.h mkmk_protos.h DoFile_protos.h GenSmake_protos.h

gensmake.o: gensmake.c mkmk.h mkmk_protos.h DoFile_protos.h GenSmake_protos.h

